# Copy this file to .env before enabling the real LLM integration.
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.5
LLM_API_KEY=your_api_key_here

# Venue provider configuration. Keep json for the controlled demo catalog.
VENUE_PROVIDER=json
VENUE_JSON_PATH=
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
GOOGLE_MAPS_BROWSER_API_KEY=your_referrer_restricted_browser_key_here
GOOGLE_PLACES_RADIUS_METERS=2500
GOOGLE_PLACES_MAX_RESULTS=10
GOOGLE_PLACES_LANGUAGE_CODE=tr
